{
  "name": "@hadidyapp/audio-live",
  "version": "0.1.1",
  "description": "Live streaming SDK for Hadidy Audio — LiveKit WebRTC, HLS playback, SSE session state",
  "type": "module",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@hadidyapp/audio-sdk": "^0.1.0",
    "hls.js": "^1.5.0",
    "livekit-client": "^2.5.0"
  },
  "devDependencies": {
    "@hadidyapp/audio-sdk": "^0.1.0",
    "@types/node": "^22.0.0",
    "hls.js": "^1.5.0",
    "livekit-client": "^2.5.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "keywords": ["audio", "live", "livekit", "hls", "streaming", "hadidy", "sdk"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hadidybase/audio-live.git"
  }
}
